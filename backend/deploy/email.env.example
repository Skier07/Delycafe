# Уведомления администратору об оплаченных заказах (Mail.ru SMTP).
# Скопируйте в backend/.env на VPS. Пароль — «пароль для внешних приложений» Mail.ru.

ORDER_ADMIN_EMAIL_ENABLED=true
ORDER_ADMIN_EMAIL=pizzaozersk@mail.ru

EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=pizzaozersk@mail.ru
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=pizzaozersk@mail.ru
