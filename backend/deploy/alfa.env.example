# DelyCafe — переменные Альфа-Банк для /var/www/delycafe_backend/Delycafe/backend/.env
#
# После правок:
#   sudo systemctl restart delycafe_backend

ALFA_PAYMENT_ENABLED=true
ALFA_API_LOGIN=r-pizzaozersk-api
ALFA_API_PASSWORD=ваш_пароль

ALFA_REGISTER_URL=https://payment.alfabank.ru/payment/rest/register.do
ALFA_STATUS_URL=https://payment.alfabank.ru/payment/rest/getOrderStatusExtended.do

ALFA_RETURN_URL=https://api.delycafe.ru/api/payments/success/
ALFA_FAIL_URL=https://api.delycafe.ru/api/payments/fail/

# Callback: Альфа шлёт POST/GET сюда после оплаты (operation=deposited, status=1).
# В кабинете Альфы должны быть включены:
#   - Callback type: Dynamic (CALLBACK_TYPE=DYNAMIC)
#   - Разрешены callback-уведомления
ALFA_CALLBACK_URL=https://api.delycafe.ru/api/payments/alfa/callback/
